# ================================================================
# Frontend Environment Variables
# ================================================================
# LOCAL:    cp .env.example .env  (no REACT_APP_API_URL needed - proxy handles it)
# NETLIFY:  Set in Netlify Dashboard → Site Settings → Environment Variables

# Your Render/Railway backend URL (no trailing slash)
# Example: https://sms-marketing-backend.onrender.com
REACT_APP_API_URL=https://your-backend.onrender.com

# App name
REACT_APP_NAME=SMS Marketing System
